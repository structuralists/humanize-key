{
   "name": "humanize-key",
   "version": "0.3.0",
   "description": "formatting string keys for display",
   "keywords": [
      "humanize",
      "key",
      "string",
      "formatting",
      "camelcase",
      "snake-case",
      "kebab-case",
      "acronyms"
   ],
   "main": "dist/humanizeKey.js",
   "module": "dist/humanizeKey.mjs",
   "types": "dist/humanizeKey.d.ts",
   "files": [
      "dist"
   ],
   "author": "William Lubelski <will.lubelski@gmail.com>",
   "repository": {
      "type": "git",
      "url": "https://github.com/structuralists/humanize-key"
   },
   "license": "MIT",
   "scripts": {
      "build": "tsup",
      "typecheck": "tsc --noEmit",
      "lint": "eslint src",
      "test": "bun test"
   },
   "prettier": {
      "semi": false,
      "singleQuote": true,
      "tabWidth": 3,
      "trailingComma": "all",
      "useTabs": false,
      "arrowParens": "always"
   },
   "devDependencies": {
      "@types/bun": "latest",
      "@typescript-eslint/parser": "^8.62.1",
      "eslint": "^10.6.0",
      "prettier": "^3.9.4",
      "tsup": "^8.0.0",
      "typescript": "^6.0.3"
   },
   "publishConfig": {
      "access": "public"
   }
}
